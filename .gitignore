# macOS
.DS_Store
**/.DS_Store

# One-shot import artefacts (CSV/XLSX генерируемые в сессиях)
holded_*.csv
holded_*.xlsx
restore_*.csv
restore_*.xlsx
variants_*.csv
variants_*.xlsx
*_fix*.csv
*_fix*.xlsx
# Exception: migration audit snapshots (явно нужны в репо для трассируемости)
!pedido.files/migration/holded_*.xlsx

# Session logs (см. CHANGELOG для истории сессий)
p0_*.log
p1_*.log
pdf_attach_*.log
**/p0_*.log
**/p1_*.log
**/pdf_attach_*.log

# Stale planning JSONs (одноразовые snapshot'ы перед массовыми операциями)
post_reset_*.json
tax_audit_*.json
parex_skus.json
**/post_reset_*.json
**/tax_audit_*.json
**/parex_skus.json

# Python cache
__pycache__/
*.pyc
.venv/

# Odoo backups (large binary, never commit)
резервные копии Odoo базы/
